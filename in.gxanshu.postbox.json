{
    "id" : "in.gxanshu.postbox",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "49",
    "sdk" : "org.gnome.Sdk",
    "command" : "postbox",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "blueprint-compiler",
            "buildsystem" : "meson",
            "cleanup" : [ "*" ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://gitlab.gnome.org/jwestman/blueprint-compiler",
                    "tag" : "v0.20.4"
                }
            ]
        },
        {
            "name" : "postbox",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "dir",
                    "path" : ".",
                    "skip" : [
                        "build",
                        ".flatpak",
                        ".flatpak-builder",
                        ".git",
                        "postbox.flatpak"
                    ]
                }
            ],
            "config-opts" : [
                "--libdir=lib"
            ]
        }
    ]
}
