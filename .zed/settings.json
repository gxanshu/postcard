{
  // Project-local Zed settings for the Postbox GTK/libadwaita app.
  "languages": {
    "Python": {
      "tab_size": 4,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "-"]
        }
      }
    },
    "Blueprint": {
      "tab_size": 2
    }
  },
  // Keep build artifacts out of the file finder / project panel noise.
  "file_scan_exclusions": [
    "**/build",
    "**/.flatpak-builder",
    "**/__pycache__",
    "**/_build"
  ]
}
