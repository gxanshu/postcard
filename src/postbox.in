import gettext
import locale
import os
import signal
import sys

VERSION = "@VERSION@"
pkgdatadir = "@pkgdatadir@"
localedir = "@localedir@"

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)

locale.bindtextdomain("postbox", localedir)
locale.textdomain("postbox")
gettext.install("postbox", localedir)

if __name__ == "__main__":
    from gi.repository import Gio

    resource = Gio.Resource.load(os.path.join(pkgdatadir, "postbox.gresource"))
    resource._register()  # noqa: SLF001 — GResource._register is the public entry point

    from postbox import main

    sys.exit(main.main(VERSION))
